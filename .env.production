# ============================================
# Production Environment Variables
# ============================================
# IMPORTANT: Never commit this file to Git!
# This is a template - copy and fill in your actual values

# ---------------------------------------------
# Docker Configuration
# ---------------------------------------------
# Choose your registry: docker.io, ghcr.io, or cloud provider registry
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=yourusername/clinical-trial-assistant
VERSION=latest

# ---------------------------------------------
# OpenAI Configuration
# ---------------------------------------------
OPENAI_API_KEY=your_production_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------
# LangSmith Configuration (Optional - for monitoring)
# ---------------------------------------------
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=clinical-trial-matching-prod
LANGCHAIN_TRACING_V2=true

# ---------------------------------------------
# PostgreSQL Configuration
# ---------------------------------------------
# For managed databases (recommended):
# POSTGRES_HOST=your-db-instance.region.provider.com
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=aact
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_strong_password_here

# For Docker Compose on VM:
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=aact
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ---------------------------------------------
# Elasticsearch Configuration
# ---------------------------------------------
# For Elastic Cloud (recommended):
# ELASTICSEARCH_URL=https://your-deployment.es.region.cloud.es.io:9243
# ES_INDEX_NAME=aact

# For Docker Compose on VM:
ELASTICSEARCH_URL=http://elasticsearch:9200
ES_INDEX_NAME=aact

# ---------------------------------------------
# API Settings
# ---------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
STREAMING_ENABLED=false

# ---------------------------------------------
# LLM Settings
# ---------------------------------------------
LLM_MODEL=gpt-4o-mini
TEMPERATURE=0.0
